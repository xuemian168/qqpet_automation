{
  "name": "qq-pet-macos",
  "version": "1.2.4-clean",
  "description": "QQ宠物 macOS 干净版 - 已移除遥测和设备指纹采集",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:zip": "electron-builder --mac zip"
  },
  "dependencies": {
    "axios": "^1.3.4",
    "crypto-js": "^4.1.1",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "iconv-lite": "^0.6.3",
    "node-xlsx": "^0.23.0",
    "nodejs-websocket": "^1.7.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.qqpet.macos",
    "productName": "QQ宠物",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "!src/**/node_modules",
      "!**/*.map"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "title": "QQ宠物 ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
